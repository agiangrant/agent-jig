{
  "name": "governor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A pace-controlled, narrated, interruptible interface for supervised AI coding.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @governor/server --filter @governor/web run dev",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "ws": "^8.21.0"
  }
}
