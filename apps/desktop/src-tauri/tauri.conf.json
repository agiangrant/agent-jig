{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Jig",
  "version": "0.1.0",
  "identifier": "com.jig.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @agent-jig/web exec vite --port 1420 --strictPort",
    "beforeBuildCommand": "pnpm --filter @agent-jig/web build && pnpm --filter @agent-jig/desktop bundle:sidecar"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data: local:; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:* http://127.0.0.1:* ws://localhost:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["sidecar/server.mjs", "sidecar/node_modules"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
